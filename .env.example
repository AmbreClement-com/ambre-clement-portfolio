# === Base de données (Neon) ===
# Local : connexion DIRECTE de la branche `dev` (sans -pooler).
# Vercel : connexion POOLED (…-pooler…) de la branche de l'environnement.
DATABASE_URL="postgresql://user:password@ep-xxx.eu-central-1.aws.neon.tech/dbname?sslmode=require"

# === Authentification (Auth.js v5) ===
# Générer avec : openssl rand -base64 32
AUTH_SECRET="change-me"

# === Stockage images (S3-compatible — Cloudflare R2) ===
# Endpoint .eu obligatoire pour les buckets en juridiction UE.
S3_ENDPOINT="https://<account_id>.eu.r2.cloudflarestorage.com"
S3_REGION="auto"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
# Local/preview : ac-media-dev — production : ac-media
S3_BUCKET="ac-media-dev"
# Base publique de lecture, SANS slash final (r2.dev en dev, media.<domaine> en prod)
S3_PUBLIC_URL="https://pub-xxxxxxxx.r2.dev"

# === Site ===
NEXT_PUBLIC_SITE_URL="https://ambreclement.com"

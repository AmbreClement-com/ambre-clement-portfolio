# === Base de données (Neon) ===
# Connexion "pooled" depuis le dashboard Neon (https://neon.tech)
DATABASE_URL="postgresql://user:password@ep-xxx-pooler.eu-central-1.aws.neon.tech/dbname?sslmode=require"

# === Authentification (Auth.js v5) ===
# Générer avec : openssl rand -base64 32
AUTH_SECRET="change-me"

# === Stockage images (Cloudflare R2) ===
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="ambre-clement-media"
# Domaine public du bucket (CDN), ex: https://media.ambreclement.com
R2_PUBLIC_URL="https://media.example.com"

# === Site ===
NEXT_PUBLIC_SITE_URL="https://ambreclement.com"
